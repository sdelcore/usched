#!/usr/bin/env bash
# Backwards-compat shim: forwards to `usched __run-job <job-id>`.
#
# Old systemd .service / at queue entries point at this script. The Rust
# runner (in the `usched` binary) now owns constraint enforcement and
# history recording — this shim just forwards the job id and ignores any
# trailing legacy command args (the runner reads the command from
# jobs.json).
#
# Safe to delete once `usched sync` has rewritten all legacy unit files.

set -euo pipefail

if [[ $# -lt 1 ]]; then
    echo "usage: usched-run <job-id> [legacy-args...]" >&2
    exit 1
fi

exec usched __run-job "$1"
